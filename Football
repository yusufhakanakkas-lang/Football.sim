<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CoreLife: Football Superstar</title>
    <style>
        :root {
            --bg-dark: #0f172a;
            --panel-bg: #1e293b;
            --border-color: #334155;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent-green: #22c55e;
            --accent-blue: #3b82f6;
            --accent-gold: #eab308;
            --accent-red: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            user-select: none;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            padding: 10px;
            display: flex;
            justify-content: center;
        }

        .game-container {
            width: 100%;
            max-width: 1000px;
            background: #111827;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 15px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.7);
        }

        /* Dash Headers */
        .header-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 10px;
            background: var(--panel-bg);
            padding: 12px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            margin-bottom: 15px;
        }

        .header-card {
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .card-label {
            font-size: 10px;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.5px;
            font-weight: 700;
        }

        .card-value {
            font-size: 15px;
            font-weight: 800;
            margin-top: 2px;
        }

        /* Layout Grid */
        .grid-layout {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 15px;
        }

        @media (max-width: 768px) {
            .grid-layout { grid-template-columns: 1fr; }
        }

        .column {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .panel {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 15px;
        }

        .panel-header {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--accent-blue);
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 6px;
            margin-bottom: 12px;
            letter-spacing: 1px;
            display: flex;
            justify-content: space-between;
        }

        /* Lists & Rows */
        .data-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 13px;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }

        .data-row span:last-child {
            font-weight: 700;
        }

        /* Buttons & Interactions */
        .btn {
            background: #334155;
            color: white;
            border: 1px solid transparent;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 700;
            transition: background 0.15s;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .btn:hover { background: #475569; }
        .btn-green { background: var(--accent-green); }
        .btn-green:hover { background: #16a34a; }
        .btn-blue { background: var(--accent-blue); }
        .btn-blue:hover { background: #2563eb; }

        .action-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        /* Match Log Commentary Box */
        .match-feed {
            background: #090d16;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            height: 160px;
            overflow-y: auto;
            padding: 10px;
            font-family: monospace;
            font-size: 12px;
            line-height: 1.5;
            color: #38bdf8;
        }

        /* Overlay */
        .overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            justify-content: center;
            align-items: center;
            z-index: 1000;
            padding: 15px;
        }

        .modal {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            width: 100%;
            max-width: 460px;
            padding: 20px;
        }

        .modal-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--accent-gold);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .modal-body {
            font-size: 13px;
            line-height: 1.5;
            color: #cbd5e1;
            margin-bottom: 15px;
        }

        .flex-buttons {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
    </style>
</head>
<body>

    <div class="game-container">
        <div class="header-grid">
            <div class="header-card">
                <span class="card-label">Net Worth</span>
                <span id="ui-money" style="color: var(--accent-green);">$500</span>
            </div>
            <div class="header-card">
                <span class="card-label">Energy</span>
                <span id="ui-energy">100/100</span>
            </div>
            <div class="header-card">
                <span class="card-label">Player OVR</span>
                <span id="ui-ovr" style="color: var(--accent-gold);">45</span>
            </div>
            <div class="header-card">
                <span class="card-label">Current Club</span>
                <span id="ui-club" style="color: #60a5fa;">EFL League Two</span>
            </div>
            <div class="header-card">
                <span class="card-label">Timeline</span>
                <span id="ui-timeline">Year 1, Fixture 1</span>
            </div>
        </div>

        <div class="grid-layout">
            
            <div class="column">
                <div class="panel">
                    <div class="panel-header">Performance Attributes</div>
                    <div class="data-row"><span>👟 Striking Power:</span> <span id="attr-pace">45</span></div>
                    <div class="data-row"><span>🎯 Vision & Passing:</span> <span id="attr-passing">45</span></div>
                    <div class="data-row"><span>🪄 Ball Control:</span> <span id="attr-dribbling">45</span></div>
                    <div class="data-row"><span>💪 Physical Stamina:</span> <span id="attr-stamina">45</span></div>
                </div>

                <div class="panel">
                    <div class="panel-header">Career Achievements & History</div>
                    <div class="data-row"><span>Club Matches / Goals:</span> <span id="stat-club-history">0 Apps / 0 G</span></div>
                    <div class="data-row"><span>International Caps / Goals:</span> <span id="stat-intl-history">0 Caps / 0 G</span></div>
                    <div class="data-row"><span>Silverware Cups Won:</span> <span id="stat-trophies" style="color:var(--accent-gold);">0 Trophies</span></div>
                    <div class="data-row"><span>National Status:</span> <span id="stat-national-status">Uncalled</span></div>
                </div>
            </div>

            <div class="column">
                <div class="panel">
                    <div class="panel-header">The Complex Engine Center</div>
                    <div class="match-feed" id="live-feed">Welcome to CoreLife Football. Train up your technical attributes, secure club transfers, and win international glory.</div>
                    
                    <div class="action-grid" style="margin-top:12px;">
                        <button class="btn" onclick="trainSkill('pace')">⚽ Train Shooting (-20⚡)</button>
                        <button class="btn" onclick="trainSkill('passing')">🎯 Train Passing (-20⚡)</button>
                        <button class="btn" onclick="trainSkill('dribbling')">🪄 Train Dribble (-20⚡)</button>
                        <button class="btn" onclick="trainSkill('stamina')">💪 Train Stamina (-20⚡)</button>
                    </div>
                    <button class="btn btn-green" style="width:100%; margin-top:8px;" onclick="recoverEnergy()">💤 Sleep & Recover Energy</button>
                </div>

                <div class="panel">
                    <div class="panel-header">Career Actions</div>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 8px;">
                        <button class="btn btn-blue" onclick="triggerTransferMarket()">💼 Transfer Requests</button>
                        <button class="btn" onclick="signEndorsement()">👔 Sponsorships</button>
                    </div>
                    <button class="btn btn-green" style="width:100%; margin-top:8px; font-size:14px;" onclick="playFixture()">🏆 SIMULATE NEXT FIXTURE MATCH</button>
                </div>
            </div>

        </div>
    </div>

    <div class="overlay" id="modal-overlay">
        <div class="modal">
            <h3 class="modal-title" id="m-title">Title Text</h3>
            <p class="modal-body" id="m-body">Body Text information.</p>
            <div class="flex-buttons" id="m-buttons">
                </div>
        </div>
    </div>

    <script>
        // CORE STATE DATA
        let core = {
            money: 500,
            energy: 100,
            pace: 45,
            passing: 45,
            dribbling: 45,
            stamina: 45,
            
            club: "Grimsby Town (Tier 4)",
            tier: 4,
            wage: 150,
            
            fixture: 1,
            year: 1,
            
            clubApps: 0,
            clubGoals: 0,
            clubAssists: 0,
            intlCaps: 0,
            intlGoals: 0,
            trophies: 0,
            
            hasNationalCall: false,
            sponsorLevel: 0
        };

        const tiers = [
            { name: "Grimsby Town (Tier 4)", tier: 4, minOvr: 0, wage: 150 },
            { name: "Sunderland AFC (Tier 2)", tier: 2, minOvr: 55, wage: 900 },
            { name: "Aston Villa (Tier 1)", tier: 1, minOvr: 70, wage: 4500 },
            { name: "Real Madrid (Elite Tier)", tier: 0, minOvr: 84, wage: 35000 }
        ];

        function getOverall() {
            return Math.round((core.pace + core.passing + core.dribbling + core.stamina) / 4);
        }

        function refreshUI() {
            document.getElementById('ui-money').innerText = `$${core.money.toLocaleString()}`;
            document.getElementById('ui-energy').innerText = `${core.energy}/100`;
            document.getElementById('ui-ovr').innerText = getOverall();
            document.getElementById('ui-club').innerText = core.club;
            document.getElementById('ui-timeline').innerText = `Year ${core.year}, Fix ${core.fixture}/10`;

            document.getElementById('attr-pace').innerText = core.pace;
            document.getElementById('attr-passing').innerText = core.passing;
            document.getElementById('attr-dribbling').innerText = core.dribbling;
            document.getElementById('attr-stamina').innerText = core.stamina;

            document.getElementById('stat-club-history').innerText = `${core.clubApps} Apps / ${core.clubGoals} Goals`;
            document.getElementById('stat-intl-history').innerText = `${core.intlCaps} Caps / ${core.intlGoals} Goals`;
            document.getElementById('stat-trophies').innerText = `${core.trophies} Trophies`;
            document.getElementById('stat-national-status').innerText = core.hasNationalCall ? "🇨🇳 Called Up (Intl)" : "No National Call";
        }

        function appendLog(txt) {
            const f = document.getElementById('live-feed');
            f.innerHTML = txt + "<br><br>" + f.innerHTML;
        }

        function trainSkill(s) {
            if (core.energy < 20) {
                appendLog("❌ System Warning: Stamina and energy stores completely depleted. Cannot complete workout.");
                return;
            }
            core.energy -= 20;
            let val = Math.floor(Math.random() * 3) + 2;
            core[s] += val;
            appendLog(`🏋️ Training complete: Your <strong>${s.toUpperCase()}</strong> attribute increased by +${val}.`);
            refreshUI();
        }

        function recoverEnergy() {
            core.energy = Math.min(100, core.energy + 50);
            appendLog("💤 Rest mode activated. Energy reserves partially restored (+50⚡).");
            refreshUI();
        }

        function showOverlay(title, body, buttonsHTML) {
            document.getElementById('m-title').innerText = title;
            document.getElementById('m-body').innerHTML = body;
            document.getElementById('m-buttons').innerHTML = buttonsHTML;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function hideOverlay() {
            document.getElementById('modal-overlay').style.display = 'none';
        }

        function triggerTransferMarket() {
            let ovr = getOverall();
            let b = "";
            tiers.forEach(t => {
                if (ovr >= t.minOvr && core.club !== t.name) {
                    b += `<button class="btn btn-blue" onclick="signContract('${t.name}', ${t.wage}, ${t.tier})">Sign for ${t.name} (Wage: $${t.wage}/wk)</button>`;
                }
            });
            b += `<button class="btn" onclick="hideOverlay()">Close Window</button>`;
            showOverlay("Transfer Window Bids", "Clubs checking your scouting metrics profile parameters:", b);
        }

        function signContract(name, wage, tier) {
            core.club = name;
            core.wage = wage;
            core.tier = tier;
            appendLog(`💼 Contract signed with <strong>${name}</strong>! Compensation updated.`);
            hideOverlay();
            refreshUI();
        }

        function signEndorsement() {
            let ovr = getOverall();
            if (ovr < 60) {
                showOverlay("Commercial Deals", "Sponsors require at least an OVR rank rating of 60 to initiate a contract offer.", `<button class="btn" onclick="hideOverlay()">Back</button>`);
                return;
            }
            core.sponsorLevel += 1;
            let deal = core.sponsorLevel * 300;
            core.money += deal;
            appendLog(`👔 Endorsement payout: Secured a marketing campaign payout worth $${deal}.`);
            hideOverlay();
            refreshUI();
        }

        // MATCH DAY ENGINE REBUILD
        function playFixture() {
            if (core.energy < 25) {
                appendLog("❌ Engine Interruption: Energy critical (<25⚡). Match simulation unsafe.");
                return;
            }
            core.energy -= 25;
            
            // Check National call rating parameter logic
            if (getOverall() >= 75 && !core.hasNationalCall) {
                core.hasNationalCall = true;
                appendLog("🇨🇳 BREAKING INTELLIGENCE: Your global scouting ranking has triggered a Call up to the National Team for the World Cup!");
            }

            let isIntlMatch = core.hasNationalCall && (core.fixture === 5 || core.fixture === 10);
            let teamName = isIntlMatch ? "National Squad" : "Your Club";
            
            appendLog(`🎮 Kickoff: Simulating Match Day Fixture ${core.fixture}...`);

            // Minute processing
            let g = 0; let a = 0;
            let rng1 = Math.random() * 100;
            let ovr = getOverall();

            if (ovr > rng1) { g++; }
            if (ovr > (rng1 + 20)) { a++; }

            if (isIntlMatch) {
                core.intlCaps++;
                core.intlGoals += g;
            } else {
                core.clubApps++;
                core.clubGoals += g;
            }

            core.money += core.wage;
            
            let resTitle = `${teamName} Simulation Complete`;
            let resBody = `Match Performance summary parameters tracked:<br>⚽ Goals: ${g}<br>🎯 Assists: ${a}<br>💰 Match Day Wage Earned: +$${core.wage}`;
            
            // Generate interactive option scenarios
            let choiceBtn = `<button class="btn btn-green" onclick="advanceTimeline(${g}, ${isIntlMatch})">Continue Progress</button>`;
            showOverlay(resTitle, resBody, choiceBtn);
        }

        function advanceTimeline(goals, wasIntl) {
            hideOverlay();
            core.fixture++;
            
            if (core.fixture > 10) {
                core.fixture = 1;
                core.year++;
                core.trophies++;
                appendLog(`🏆 TOURNAMENT WINNER: Season cycle finalized! Trophy awarded to cabinet portfolio.`);
            }
            refreshUI();
        }

        refreshUI();
    </script>
</body>
</html>
